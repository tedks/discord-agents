# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Discord harness for AI agents (Claude, Codex, Gemini)"
description:
  "A Discord bot that manages AI agent sessions across projects. Creates channels per project, threads per agent session, and bridges communication between Discord and agent subprocesses."
maintainer: ["Ted Suzman"]
authors: ["Ted Suzman"]
license: "AGPL-3.0-or-later"
homepage: "https://github.com/tedks/discord-agents"
bug-reports: "https://github.com/tedks/discord-agents/issues"
depends: [
  "ocaml" {>= "5.1.0"}
  "dune" {>= "3.14"}
  "eio_main" {>= "1.0"}
  "cohttp-eio" {>= "6.0"}
  "uri"
  "ca-certs"
  "mirage-crypto-rng" {>= "1.0"}
  "yojson" {>= "2.0"}
  "ppx_yojson_conv"
  "ppx_deriving"
  "tls-eio" {>= "1.0"}
  "logs" {>= "0.7"}
  "fmt"
  "alcotest" {with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/tedks/discord-agents.git"
